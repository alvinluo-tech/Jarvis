# AI Provider: "mimo" | "groq" | "openrouter" | "local"
AI_PROVIDER=mimo
AI_MODEL=mimo-v2.5-pro

# MiMo AI API (default provider)
MIMO_API_KEY=your_mimo_api_key
MIMO_API_URL=https://token-plan-ams.xiaomimimo.com/v1

# Groq (for ASR and fallback LLM)
GROQ_API_KEY=your_groq_api_key

# OpenRouter
OPENROUTER_API_KEY=your_openrouter_api_key

# Ollama (local model)
OLLAMA_BASE_URL=http://localhost:11434/v1

# Storage Mode: "local" (SQLite) or "cloud" (Supabase)
STORAGE_MODE=local

# Supabase (required for cloud mode)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# Local Database
SQLITE_DB_PATH=./data/jarvis.db

# Daemon
DAEMON_PORT=3001
DAEMON_HOST=localhost
